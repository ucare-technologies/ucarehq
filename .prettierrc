{
	"trailingComma": "es5",
	"singleQuote": true,
	"printWidth": 120,
	"tabWidth": 2,
	"useTabs": true,
	"semi": true,
	"bracketSpacing": true,
	"jsxSingleQuote": true,
	"arrowParens": "avoid",
	"plugins": ["prettier-plugin-astro", "@trivago/prettier-plugin-sort-imports"],
	"importOrder": [
		"(^react$|^react/(.*)$)",
		"<THIRD_PARTY_MODULES>",
		"^~/(.*)$",
		"^[./]",
		".svg",
		".(css|scss)"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		}
	]
}
