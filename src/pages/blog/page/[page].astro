---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getBlogPageData } from '../../../lib/contentful/queries';
import { AllPosts } from '../../../components/blogs/posts';

export async function getStaticPaths() {
	const data = await getBlogPageData(1);
	const pages = Array.from({ length: Math.max(0, data.numPages - 1) }, (_, index) => String(index + 2));
	return pages.map(page => ({
		params: { page },
	}));
}

const pageNumber = Number(Astro.params.page || '1');
const data = await getBlogPageData(pageNumber);
const titleBase = (data.blogsPageData.all_blog_section as string | null) || 'Blog';
const title = data.currentPage === 1 ? titleBase : `${titleBase} | Page ${data.currentPage}`;
---

<BaseLayout title={title}>
	<AllPosts client:load blogsPageData={data.blogsPageData} currentPage={data.currentPage} limit={data.limit} />
</BaseLayout>
